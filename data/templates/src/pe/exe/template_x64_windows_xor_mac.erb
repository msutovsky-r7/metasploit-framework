#define SCSIZE <%= encoded_payload_length %>
#define SCSIZE_ENC <%= encrypted_payload_length %>

char bPayload[SCSIZE_ENC];
char bPayloadEncoded[<%= encrypted_payload.length %>] = "<%= encrypted_payload %>";
char bControlBytes[<%= encryption_rounds %>] = "<%= control_bytes %>";

typedef union _LARGE_INTEGER {
